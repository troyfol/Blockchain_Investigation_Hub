    { "id": "light", "label": "Light (Clean)", "description": "Locked modern-clean light theme." },
    { "id": "print-light", "label": "Print Light", "description": "Ink-light, neutral palette for printed/exported case files (report + exhibit) — never the canvas." }
  ],
