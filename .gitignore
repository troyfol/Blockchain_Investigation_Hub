# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.hypothesis/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Environment / secrets
.env
.env.*
!.env.example
# Code-signing certs / private keys must NEVER be committed (P9 signing reads these from paths/env).
*.pfx
*.p12
*.snk

# Runtime case folders are user data — never committed (CLAUDE.md §3).
cases/
# ...but keep the directory present in the tree.
!cases/.gitkeep

# Shared library cache DB (performance only; not part of any case).
library_cache.db
*.db-wal
*.db-shm

# Portable case bundles are user data — EXCEPT the committed showcase sample under examples/ (P10).
*.casefile
!examples/**/*.casefile

# Build/release scratch the showcase + installer produce (the committed sample lives under examples/).
installer/Output/

# Node / frontend
node_modules/
frontend/dist/
frontend/.vite/

# Playwright
/test-results/
/playwright-report/

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code / agent-local config (carries local paths + permissions — never ship)
.claude/
# Two build-workflow files stay at the repo ROOT (both gitignored so pushes never include them): CLAUDE.md is
# auto-loaded by the harness as the project contract, and PROGRESS.md (the build journal) is referenced
# throughout the PUBLISHED build docs (docs/phases/*, roadmap, BUILD_INDEX, …) — moving it would strand those.
CLAUDE.md
PROGRESS.md
# ALL OTHER non-published internal docs are consolidated + ignored here, so a `git add -A` can never leak them
# (they were previously untracked-but-not-ignored — a real leak risk): the upgrade/ + review/ dev logs,
# UPGRADE_PROMPT.md, and the private QUICKSTART.md tutorial. Published docs (README,
# docs/review/RELEASE_NOTES_*, docs/validation/*, the phase/build docs) stay tracked.
docs/internal/
