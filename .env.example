# Example env file — copy to .env and fill in. NEVER commit real secrets.
# Real API keys belong in the OS keyring (see backend/app/secrets.py).

# Loud dev-only opt-in to read secrets from BIH_SECRET_<NAME> env vars instead of keyring:
# BIH_ALLOW_PLAINTEXT_KEYS=1
# BIH_SECRET_ETHERSCAN=your-key-here

# Connector toggles / tiers:
# BIH_ETHERSCAN_PAID_TIER=0
# BIH_CACHE_TTL_DAYS=30
